# Generated by Android Studio

# Folders and files to ignore in an Android Studio project

# Built application files
*.apk
*.aab
*.ap_
*.dex

# Built Jar-, AAR- and WAR-archives
*.jar
*.aar
*.war

# Keystore files
#
# Don't add the keystore to version control.
# See https://developer.android.com/studio/publish/app-signing#secure-shared-keystore
*.keystore
keystore.properties

# Other sensitive files
service-account.json

# Generated files
/build
/captures
.externalNativeBuild
.cxx
*.class

# Local configuration files (sdk, ndk, keystore)
local.properties

# Log files
*.log
build_output.log

# Profiler & Debugger files
*.hprof
*.snapshot
*.apc

# Android Studio and IntelliJ IDEA files
.gradle
.idea/
*.iml
*.ipr
*.iws
.DS_Store

# Gradle
.gradle/
build/

# Caches
.idea/caches/
.idea/libraries/

# User-specific files
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries/
.idea/shelf/
.idea/modules.xml
.idea/navEditor.xml
.agent
